'use client';

import React from 'react';
import Link from 'next/link';
import { useRouter, useParams } from 'next/navigation';
import { useSession } from 'next-auth/react';

interface DashboardData {
  summary: {
    total_original_budget: number;
    total_committed: number;
    total_paid: number;
    total_available: number;
    usage_percentage: number;
  };
  categoryStatuses: any[];
  overBudgetCategories: any[];
  highUsageCategories: any[];
  unassignedPurchases: any[];
  topSuppliers: any[];
}

export default function ProjectDashboard() {
  const { data: session, status } = useSession();
  const router = useRouter();
  const { projectId } = useParams() as { projectId: string };

  const [project, setProject] = React.useState<any>(null);
  const [dashboard, setDashboard] = React.useState<DashboardData | null>(null);
  const [loading, setLoading] = React.useState(true);

  React.useEffect(() => {
    if (status === 'unauthenticated') {
      router.push('/login');
    }
  }, [status, router]);

  React.useEffect(() => {
    if (session && projectId) {
      loadProjectData();
    }
  }, [session, projectId]);

  const loadProjectData = async () => {
    try {
      setLoading(true);
      
      const [projectRes, dashboardRes] = await Promise.all([
        fetch(`/api/projects/${projectId}`),
        fetch(`/api/projects/${projectId}/dashboard`),
      ]);

      if (projectRes.ok) {
        const projectData = await projectRes.json();
        setProject(projectData.data);
      }

      if (dashboardRes.ok) {
        const dashData = await dashboardRes.json();
        setDashboard(dashData.data);
      }
    } catch (error) {
      console.error('Error loading project data:', error);
    } finally {
      setLoading(false);
    }
  };

  const formatCurrency = (amount: number) => {
    const symbol = project?.currency === 'USD' ? '$' : 'RD$';
    return `${symbol} ${amount.toLocaleString('es-DO', {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2,
    })}`;
  };

  if (status === 'loading' || loading) {
    return (
      <div className="min-h-screen bg-gray-50 flex items-center justify-center">
        <div className="text-center">
          <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mx-auto mb-4"></div>
          <p>Cargando datos del proyecto...</p>
        </div>
      </div>
    );
  }

  if (!project) {
    return (
      <div className="min-h-screen bg-gray-50 flex items-center justify-center">
        <div className="text-center">
          <p className="text-red-600">No se pudo cargar el proyecto</p>
          <Link href="/projects" className="text-blue-600 hover:underline mt-4 block">
            Volver a proyectos
          </Link>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-gray-50">
      {/* Header */}
      <header className="bg-white shadow">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
          <div className="flex justify-between items-center mb-4">
            <div>
              <Link
                href="/projects"
                className="text-blue-600 hover:underline text-sm mb-2 block"
              >
                ← Volver a Proyectos
              </Link>
              <h1 className="text-3xl font-bold text-gray-900">{project.name}</h1>
              {project.client_name && (
                <p className="text-gray-600">Cliente: {project.client_name}</p>
              )}
            </div>
            <div className="text-right">
              <span className={`px-4 py-2 rounded-lg text-sm font-medium ${
                project.status === 'active'
                  ? 'bg-green-100 text-green-800'
                  : 'bg-gray-100 text-gray-800'
              }`}>
                {project.status === 'active' ? 'Activo' : 'Pausado'}
              </span>
            </div>
          </div>

          {/* Navigation */}
          <nav className="flex gap-4 border-t pt-4">
            <Link
              href={`/projects/${projectId}`}
              className="text-blue-600 font-medium border-b-2 border-blue-600 pb-2"
            >
              📊 Dashboard
            </Link>
            <Link
              href={`/projects/${projectId}/budget`}
              className="text-gray-600 hover:text-gray-900 pb-2"
            >
              💰 Presupuesto
            </Link>
            <Link
              href={`/projects/${projectId}/purchases`}
              className="text-gray-600 hover:text-gray-900 pb-2"
            >
              🛒 Compras
            </Link>
          </nav>
        </div>
      </header>

      {/* Main Content */}
      <main className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        {/* Budget Summary Cards */}
        {dashboard?.summary && (
          <div className="grid grid-cols-1 md:grid-cols-5 gap-4 mb-8">
            <div className="bg-white p-6 rounded-lg shadow">
              <h3 className="text-sm font-medium text-gray-600">Presupuesto Original</h3>
              <p className="text-2xl font-bold text-gray-900 mt-2">
                {formatCurrency(dashboard.summary.total_original_budget)}
              </p>
            </div>

            <div className="bg-white p-6 rounded-lg shadow">
              <h3 className="text-sm font-medium text-gray-600">Comprometido</h3>
              <p className="text-2xl font-bold text-blue-600 mt-2">
                {formatCurrency(dashboard.summary.total_committed)}
              </p>
            </div>

            <div className="bg-white p-6 rounded-lg shadow">
              <h3 className="text-sm font-medium text-gray-600">Pagado</h3>
              <p className="text-2xl font-bold text-green-600 mt-2">
                {formatCurrency(dashboard.summary.total_paid)}
              </p>
            </div>

            <div className="bg-white p-6 rounded-lg shadow">
              <h3 className="text-sm font-medium text-gray-600">Disponible</h3>
              <p className={`text-2xl font-bold mt-2 ${
                dashboard.summary.total_available < 0 ? 'text-red-600' : 'text-gray-900'
              }`}>
                {formatCurrency(dashboard.summary.total_available)}
              </p>
            </div>

            <div className="bg-white p-6 rounded-lg shadow">
              <h3 className="text-sm font-medium text-gray-600">Uso</h3>
              <p className={`text-2xl font-bold mt-2 ${
                dashboard.summary.usage_percentage > 100 ? 'text-red-600'
                  : dashboard.summary.usage_percentage > 80 ? 'text-yellow-600'
                  : 'text-green-600'
              }`}>
                {dashboard.summary.usage_percentage.toFixed(1)}%
              </p>
              <div className="w-full bg-gray-200 rounded-full h-2 mt-3">
                <div
                  className={`h-2 rounded-full ${
                    dashboard.summary.usage_percentage > 100 ? 'bg-red-600' : 'bg-green-600'
                  }`}
                  style={{
                    width: `${Math.min(dashboard.summary.usage_percentage, 100)}%`,
                  }}
                ></div>
              </div>
            </div>
          </div>
        )}

        {/* Alerts */}
        <div className="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
          {dashboard?.overBudgetCategories && dashboard.overBudgetCategories.length > 0 && (
            <div className="bg-red-50 border-l-4 border-red-500 p-4 rounded">
              <h3 className="font-bold text-red-900 mb-2">
                ⚠️ Sobre Presupuesto ({dashboard.overBudgetCategories.length})
              </h3>
              <ul className="text-sm text-red-800 space-y-1">
                {dashboard.overBudgetCategories.slice(0, 3).map((cat, i) => (
                  <li key={i}>
                    {cat.category}: {cat.usage_percentage.toFixed(1)}%
                  </li>
                ))}
              </ul>
            </div>
          )}

          {dashboard?.highUsageCategories && dashboard.highUsageCategories.length > 0 && (
            <div className="bg-yellow-50 border-l-4 border-yellow-500 p-4 rounded">
              <h3 className="font-bold text-yellow-900 mb-2">
                ⚡ Alto Uso (>80%) ({dashboard.highUsageCategories.length})
              </h3>
              <ul className="text-sm text-yellow-800 space-y-1">
                {dashboard.highUsageCategories.slice(0, 3).map((cat, i) => (
                  <li key={i}>
                    {cat.category}: {cat.usage_percentage.toFixed(1)}%
                  </li>
                ))}
              </ul>
            </div>
          )}

          {dashboard?.unassignedPurchases && dashboard.unassignedPurchases.length > 0 && (
            <div className="bg-blue-50 border-l-4 border-blue-500 p-4 rounded">
              <h3 className="font-bold text-blue-900 mb-2">
                📌 Sin Categoría ({dashboard.unassignedPurchases.length})
              </h3>
              <p className="text-sm text-blue-800">
                Compras esperando asignación
              </p>
              <Link
                href={`/projects/${projectId}/purchases`}
                className="text-blue-600 hover:underline text-sm mt-2 block"
              >
                Ver compras →
              </Link>
            </div>
          )}
        </div>

        {/* Category Status Table */}
        {dashboard?.categoryStatuses && dashboard.categoryStatuses.length > 0 && (
          <div className="bg-white rounded-lg shadow overflow-hidden mb-8">
            <div className="px-6 py-4 border-b">
              <h2 className="text-xl font-bold">Estado del Presupuesto por Categoría</h2>
            </div>
            <div className="overflow-x-auto">
              <table className="w-full">
                <thead className="bg-gray-50">
                  <tr>
                    <th className="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase">
                      Categoría
                    </th>
                    <th className="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase">
                      Presupuesto
                    </th>
                    <th className="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase">
                      Usado
                    </th>
                    <th className="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase">
                      Disponible
                    </th>
                    <th className="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase">
                      Uso %
                    </th>
                  </tr>
                </thead>
                <tbody className="divide-y divide-gray-200">
                  {dashboard.categoryStatuses.map((cat) => (
                    <tr key={cat.budget_item_id} className={cat.is_over_budget ? 'bg-red-50' : ''}>
                      <td className="px-6 py-4 text-sm">
                        <p className="font-medium">{cat.category}</p>
                        <p className="text-xs text-gray-500">{cat.description}</p>
                      </td>
                      <td className="px-6 py-4 text-sm">
                        {formatCurrency(cat.total_budget)}
                      </td>
                      <td className="px-6 py-4 text-sm">
                        {formatCurrency(cat.committed)}
                      </td>
                      <td className="px-6 py-4 text-sm">
                        <span className={cat.available < 0 ? 'text-red-600 font-bold' : ''}>
                          {formatCurrency(cat.available)}
                        </span>
                      </td>
                      <td className="px-6 py-4 text-sm">
                        <div className="flex items-center gap-2">
                          <div className="w-16 bg-gray-200 rounded-full h-2">
                            <div
                              className={`h-2 rounded-full ${
                                cat.is_over_budget ? 'bg-red-600' : 'bg-blue-600'
                              }`}
                              style={{
                                width: `${Math.min(cat.usage_percentage, 100)}%`,
                              }}
                            ></div>
                          </div>
                          <span className={cat.is_over_budget ? 'text-red-600 font-bold' : ''}>
                            {cat.usage_percentage.toFixed(1)}%
                          </span>
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}

        {/* Top Suppliers */}
        {dashboard?.topSuppliers && dashboard.topSuppliers.length > 0 && (
          <div className="bg-white rounded-lg shadow p-6">
            <h2 className="text-xl font-bold mb-4">Proveedores Principales</h2>
            <div className="overflow-x-auto">
              <table className="w-full">
                <thead>
                  <tr className="border-b">
                    <th className="text-left py-2 font-medium">Proveedor</th>
                    <th className="text-left py-2 font-medium">Total</th>
                    <th className="text-left py-2 font-medium">Compras</th>
                  </tr>
                </thead>
                <tbody>
                  {dashboard.topSuppliers.map((supplier, idx) => (
                    <tr key={idx} className="border-b hover:bg-gray-50">
                      <td className="py-3">{supplier.supplier_name}</td>
                      <td className="py-3">{formatCurrency(supplier.total_amount)}</td>
                      <td className="py-3">{supplier.purchase_count}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}
      </main>
    </div>
  );
}
